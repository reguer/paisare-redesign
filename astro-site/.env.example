# ============================================================
# Paisare Astro — Variables de entorno
# Copiar a .env y completar valores reales (nunca commitear .env)
# Ver docs/infra/cicd.md para instrucciones de configuración en CF Pages
# ============================================================

# Sanity — obtener en sanity.io/manage → API → Project ID
PUBLIC_SANITY_PROJECT_ID=
PUBLIC_SANITY_DATASET=production

# Web3Forms — obtener en web3forms.com → dashboard
PUBLIC_WEB3FORMS_KEY=

# Sanity API Token (privado — rol "Read" únicamente)
SANITY_API_TOKEN=

# Mercado Pago — obtener en developers.mercadopago.com (requerido en Fase 6)
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=

# Cloudflare Access Audience Tag (requerido en Fase 5)
CF_ACCESS_AUD=
